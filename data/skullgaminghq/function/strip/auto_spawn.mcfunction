## Auto-spawn pending markers for nearby stripped logs (works even if advancement doesn't trigger)
# Run as the player at their position; spawns a single pending marker per stripped log

execute as @s at @s positioned ^ ^ ^1 if block ~ ~ ~ minecraft:stripped_oak_log unless entity @e[type=minecraft:armor_stand,tag=skull_strip_pending,distance=..0.25] unless entity @e[type=minecraft:armor_stand,tag=skull_strip_processed,distance=..0.25] run summon minecraft:armor_stand ~ ~ ~ {Tags:["skull_strip_pending","skull_strip_processed"],Marker:1b,Invisible:1b,NoGravity:1b,PersistenceRequired:1b}
